# ======================
# Server Configuration
# ======================
NODE_ENV=development
PORT=3003

# ======================
# Database Configuration
# ======================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=admin_saas
DB_PORT=3306

# ======================
# JWT Configuration
# ======================
# IMPORTANT: Use strong, random secrets (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters_required
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_minimum_32_characters_required

# JWT Expiration Times
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# JWT Issuer/Audience (optional)
JWT_ISSUER=admin-saas
JWT_AUDIENCE=admin-saas-api

# ======================
# CORS Configuration
# ======================
CORS_ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3003

# ======================
# Email (SMTP) Configuration
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Email Sender Details
EMAIL_FROM_NAME=Admin SaaS
EMAIL_FROM_ADDRESS=noreply@admin-saas.com

# Admin Panel URL (for email links)
ADMIN_PANEL_URL=http://localhost:5174

# ======================
# Redis Configuration (Optional)
# ======================
# For distributed rate limiting and caching
REDIS_URL=redis://localhost:6379

# ======================
# 🔒 SECURITY: IP Change Detection Policy
# ======================
# Controls behavior when a refresh token is used from a different IP address
#
# Options:
#   "log"    - Only log the IP change (default in development)
#   "block"  - Revoke token and require re-login (default in production)
#   "notify" - Send email notification and allow refresh
#
# Production recommendation: "block" (most secure)
IP_CHANGE_POLICY=block

# ======================
# API Key (Optional)
# ======================
# For server-to-server authentication (no-origin requests)
# Leave empty to disable
API_KEY=

# ======================
# File Upload Configuration
# ======================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./public/uploads

# ======================
# Rate Limiting
# ======================
# Auth endpoints (login, refresh)
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000

# Global rate limit
GLOBAL_RATE_LIMIT_MAX=1000
GLOBAL_RATE_LIMIT_WINDOW_MS=900000
